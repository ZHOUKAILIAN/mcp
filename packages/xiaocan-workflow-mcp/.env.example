# 小蚕霸王餐 MCP 配置

# MCP 服务器端口
PORT=7788

# 默认城市代码 (上海=310100, 北京=110100, 广州=440100, 深圳=440300)
XIAOCAN_CITY_CODE=310100

# 默认经纬度 (上海外滩)
XIAOCAN_LAT=31.23037
XIAOCAN_LNG=121.47370

# 抢单 RPC 方法名（推测值，需抓包确认）
# 在微信开发者工具或 Charles 抓包小蚕小程序抢单请求
# 找到 /rpc/ 后面的方法名，然后设置此变量
# XIAOCAN_GRAB_METHOD=SilkwormService.ApplyPromotion
